{
  "name": "workie-tokey",
  "version": "0.1.0",
  "description": "사용 중인 AI의 남은 토큰량을 보여주는 창 없는 오버레이",
  "author": "butei",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.workietokey.app",
    "productName": "WorkieTokey",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "renderer/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "build/icon.png"
    }
  }
}
